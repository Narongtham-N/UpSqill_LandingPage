{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "upsqill-landing-page",
  "version": "1.0.0",
  "description": "Reusable UpSqill landing page design tokens extracted from the current static landing page.",
  "tokens": {
    "color": {
      "$type": "color",
      "primitive": {
        "white": { "$value": "#ffffff" },
        "black": { "$value": "#000000" },
        "ink900": { "$value": "#17191c" },
        "ink800": { "$value": "#2a2d33" },
        "fog50": { "$value": "#f7f7f8" },
        "stone700": { "$value": "#4c4c4c" },
        "steel500": { "$value": "#777b86" },
        "steel300": { "$value": "#a3a6af" },
        "dusk400": { "$value": "#8b8c8d" },
        "blue500": { "$value": "#20aeea" },
        "navy700": { "$value": "#24529b" },
        "terracotta800": { "$value": "#5d2a1a" },
        "terracotta500": { "$value": "#a06450" },
        "mist100": { "$value": "#fbe1d1" },
        "mist50": { "$value": "#fff1e3" },
        "peach300": { "$value": "#f5b89c" }
      },
      "semantic": {
        "canvas": { "$value": "{color.primitive.white}" },
        "surface": { "$value": "{color.primitive.white}" },
        "surfaceMuted": { "$value": "{color.primitive.fog50}" },
        "surfaceWarm": { "$value": "{color.primitive.mist100}" },
        "surfaceWarmSoft": { "$value": "{color.primitive.mist50}" },
        "surfaceInverse": { "$value": "{color.primitive.ink900}" },
        "text": { "$value": "{color.primitive.ink900}" },
        "textStrong": { "$value": "{color.primitive.black}" },
        "textMuted": { "$value": "{color.primitive.stone700}" },
        "textSubtle": { "$value": "{color.primitive.steel500}" },
        "textDisabled": { "$value": "{color.primitive.steel300}" },
        "textInverse": { "$value": "{color.primitive.white}" },
        "brandPrimary": { "$value": "{color.primitive.blue500}" },
        "brandSecondary": { "$value": "{color.primitive.navy700}" },
        "brandWarm": { "$value": "{color.primitive.terracotta800}" },
        "borderSubtle": { "$value": "rgba(23, 25, 28, 0.08)" },
        "borderMuted": { "$value": "rgba(23, 25, 28, 0.12)" },
        "borderStrong": { "$value": "rgba(23, 25, 28, 0.18)" },
        "borderInverse": { "$value": "rgba(255, 255, 255, 0.1)" },
        "focusRing": { "$value": "rgba(32, 174, 234, 0.32)" },
        "focusField": { "$value": "rgba(32, 174, 234, 0.14)" },
        "glass": { "$value": "rgba(255, 255, 255, 0.78)" },
        "glassStrong": { "$value": "rgba(255, 255, 255, 0.86)" },
        "darkCopy": { "$value": "rgba(255, 255, 255, 0.72)" },
        "darkMuted": { "$value": "rgba(255, 255, 255, 0.5)" }
      }
    },
    "gradient": {
      "$type": "gradient",
      "brand": { "$value": "linear-gradient(135deg, #20aeea 0%, #24529b 100%)" },
      "brandDark": { "$value": "linear-gradient(135deg, #17191c 0%, #2a2d33 100%)" },
      "warm": { "$value": "linear-gradient(135deg, #fbe1d1 0%, #f5b89c 100%)" },
      "warmSection": { "$value": "linear-gradient(135deg, #fbe1d1 0%, #fff1e3 100%)" },
      "mesh": {
        "$value": "radial-gradient(at 20% 30%, rgba(32, 174, 234, 0.18) 0px, transparent 50%), radial-gradient(at 80% 20%, rgba(36, 82, 155, 0.15) 0px, transparent 50%), radial-gradient(at 70% 80%, rgba(251, 225, 209, 0.5) 0px, transparent 50%)"
      }
    },
    "typography": {
      "fontFamily": {
        "$type": "fontFamily",
        "sans": { "$value": "\"Sohne\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif" },
        "serif": { "$value": "\"Signifier\", Georgia, \"Times New Roman\", serif" },
        "thai": { "$value": "\"Sarabun\", \"Noto Sans Thai\", \"Th Sarabun New\", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif" }
      },
      "fontWeight": {
        "$type": "fontWeight",
        "regular": { "$value": 400 },
        "medium": { "$value": 500 },
        "semibold": { "$value": 600 },
        "bold": { "$value": 700 }
      },
      "fontSize": {
        "$type": "dimension",
        "2xs": { "$value": "11px" },
        "xs": { "$value": "12px" },
        "sm": { "$value": "13px" },
        "md": { "$value": "14px" },
        "base": { "$value": "16px" },
        "lg": { "$value": "17px" },
        "xl": { "$value": "19px" },
        "titleSm": { "$value": "20px" },
        "title": { "$value": "22px" },
        "titleLg": { "$value": "30px" },
        "displaySm": { "$value": "36px" },
        "displayMd": { "$value": "48px" },
        "displayLg": { "$value": "72px" },
        "stat": { "$value": "52px" },
        "score": { "$value": "60px" }
      },
      "lineHeight": {
        "$type": "number",
        "flat": { "$value": 1 },
        "tight": { "$value": 1.08 },
        "heading": { "$value": 1.18 },
        "body": { "$value": 1.5 },
        "copy": { "$value": 1.6 },
        "thai": { "$value": 1.72 }
      },
      "letterSpacing": {
        "$type": "dimension",
        "normal": { "$value": "0" }
      }
    },
    "space": {
      "$type": "dimension",
      "0": { "$value": "0" },
      "1": { "$value": "2px" },
      "2": { "$value": "4px" },
      "3": { "$value": "6px" },
      "4": { "$value": "8px" },
      "5": { "$value": "10px" },
      "6": { "$value": "12px" },
      "7": { "$value": "14px" },
      "8": { "$value": "16px" },
      "9": { "$value": "18px" },
      "10": { "$value": "20px" },
      "11": { "$value": "22px" },
      "12": { "$value": "24px" },
      "14": { "$value": "28px" },
      "16": { "$value": "32px" },
      "18": { "$value": "36px" },
      "20": { "$value": "40px" },
      "24": { "$value": "48px" },
      "28": { "$value": "56px" },
      "32": { "$value": "64px" },
      "36": { "$value": "72px" },
      "40": { "$value": "80px" },
      "48": { "$value": "96px" },
      "60": { "$value": "120px" },
      "80": { "$value": "160px" }
    },
    "size": {
      "$type": "dimension",
      "pageMaxWidth": { "$value": "1280px" },
      "contentMaxWidth": { "$value": "780px" },
      "contentWideWidth": { "$value": "980px" },
      "gutterDesktop": { "$value": "24px" },
      "gutterMobile": { "$value": "16px" },
      "sectionGap": { "$value": "96px" },
      "sectionGapMobile": { "$value": "72px" },
      "headerHeight": { "$value": "64px" },
      "buttonMinHeight": { "$value": "44px" },
      "fieldMinHeight": { "$value": "52px" },
      "iconTile": { "$value": "56px" }
    },
    "radius": {
      "$type": "dimension",
      "0": { "$value": "0" },
      "1": { "$value": "2px" },
      "2": { "$value": "6px" },
      "3": { "$value": "8px" },
      "4": { "$value": "10px" },
      "5": { "$value": "12px" },
      "6": { "$value": "14px" },
      "7": { "$value": "16px" },
      "8": { "$value": "18px" },
      "card": { "$value": "24px" },
      "sheet": { "$value": "28px" },
      "pill": { "$value": "999px" },
      "round": { "$value": "50%" }
    },
    "shadow": {
      "$type": "shadow",
      "header": { "$value": "rgba(4, 23, 43, 0.04) 0 10px 40px" },
      "headerScrolled": { "$value": "rgba(4, 23, 43, 0.1) 0 14px 50px" },
      "subtle": { "$value": "rgba(4, 23, 43, 0.05) 0 0 0 1px, rgba(0, 0, 0, 0.08) 0 18px 25px -8px, rgba(0, 0, 0, 0.06) 0 8px 10px -6px" },
      "elevated": { "$value": "rgba(4, 23, 43, 0.06) 0 0 0 1px, rgba(0, 0, 0, 0.12) 0 30px 60px -12px, rgba(0, 0, 0, 0.1) 0 18px 36px -10px" },
      "glowBlue": { "$value": "0 20px 60px -20px rgba(32, 174, 234, 0.45)" },
      "hover": { "$value": "0 10px 24px -8px rgba(0, 0, 0, 0.25)" },
      "warmHover": { "$value": "0 12px 30px -10px rgba(93, 42, 26, 0.2)" }
    },
    "motion": {
      "easing": {
        "$type": "cubicBezier",
        "out": { "$value": [0.22, 1, 0.36, 1] }
      },
      "duration": {
        "$type": "duration",
        "fast": { "$value": "160ms" },
        "base": { "$value": "200ms" },
        "medium": { "$value": "300ms" },
        "slow": { "$value": "400ms" },
        "reveal": { "$value": "800ms" },
        "data": { "$value": "1400ms" }
      },
      "distance": {
        "$type": "dimension",
        "floatY": { "$value": "14px" },
        "revealY": { "$value": "40px" }
      }
    },
    "breakpoint": {
      "$type": "dimension",
      "sm": { "$value": "640px" },
      "md": { "$value": "900px" },
      "lg": { "$value": "1120px" }
    },
    "component": {
      "button": {
        "minHeight": { "$type": "dimension", "$value": "{size.buttonMinHeight}" },
        "paddingInline": { "$type": "dimension", "$value": "{space.11}" },
        "radius": { "$type": "dimension", "$value": "{radius.pill}" }
      },
      "card": {
        "padding": { "$type": "dimension", "$value": "{space.12}" },
        "radius": { "$type": "dimension", "$value": "{radius.card}" },
        "shadow": { "$type": "shadow", "$value": "{shadow.subtle}" }
      },
      "field": {
        "minHeight": { "$type": "dimension", "$value": "{size.fieldMinHeight}" },
        "radius": { "$type": "dimension", "$value": "{radius.7}" },
        "border": { "$type": "color", "$value": "{color.semantic.borderMuted}" }
      },
      "section": {
        "gap": { "$type": "dimension", "$value": "{size.sectionGap}" },
        "gapMobile": { "$type": "dimension", "$value": "{size.sectionGapMobile}" },
        "maxWidth": { "$type": "dimension", "$value": "{size.pageMaxWidth}" }
      }
    }
  }
}
